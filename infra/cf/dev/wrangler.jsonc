{
  "$schema": "https://workers.cloudflare.com/schema/wrangler.json",
  "name": "talon-cloudflare",
  "main": "../worker/src/index.ts",
  "compatibility_date": "2026-06-13",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "vars": {
    "TALON_CONFIG_INLINE_YAML": "providers:\n  mock:\n    type: openai_compatible\n    name: mock\n    base_url: \"http://mock-llm.internal:8000\"\n    model: minimax/minimax-m2.7\n    api_key:\n      source: env\n      key: MOCK_LLM_API_KEY\ndefault_provider: mock\ncontrol_plane:\n  database:\n    driver: d1\n  message_broker:\n    driver: cf_queues\n  object_store:\n    driver: r2\n",
    "TALON_GATEWAY_CONTAINER_COUNT": "1",
    "TALON_WORKER_CONTAINER_COUNT": "1",
    "TALON_SCHEDULER_AUTH_TOKEN": "cloudflare-local-scheduler-token",
    "TALON_CF_DEV_EXTERNAL_CONTAINERS": "true",
    "TALON_CF_DEV_GATEWAY_URL": "http://gateway:50052",
    "TALON_CF_DEV_GATEWAY_GRPC_URL": "http://gateway:50051",
    "TALON_CF_DEV_WORKER_URL": "http://worker:8081",
    "MOCK_LLM_API_KEY": "local-cloudflare-e2e"
  },
  "d1_databases": [
    {
      "binding": "TALON_D1",
      "database_name": "talon-control-plane",
      "database_id": "00000000-0000-0000-0000-000000000000"
    }
  ],
  "r2_buckets": [
    {
      "binding": "TALON_R2",
      "bucket_name": "talon-objects"
    }
  ],
  "queues": {
    "producers": [
      {
        "binding": "SESSION_DISPATCH_QUEUE",
        "queue": "talon-session-dispatch"
      },
      {
        "binding": "RESOURCE_LIFECYCLE_QUEUE",
        "queue": "talon-resource-lifecycle"
      },
      {
        "binding": "SESSION_CONTROL_QUEUE",
        "queue": "talon-session-control"
      }
    ],
    "consumers": [
      {
        "queue": "talon-session-dispatch",
        "max_batch_size": 10
      },
      {
        "queue": "talon-resource-lifecycle",
        "max_batch_size": 10
      },
      {
        "queue": "talon-session-control",
        "max_batch_size": 10
      }
    ]
  },
  "durable_objects": {
    "bindings": [
      {
        "name": "SCHEDULE_SHARD",
        "class_name": "ScheduleShard"
      },
      {
        "name": "SESSION_STREAMS",
        "class_name": "SessionStreamShard"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": [
        "ScheduleShard",
        "SessionStreamShard"
      ]
    }
  ]
}
