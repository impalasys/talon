{
  "$schema": "https://workers.cloudflare.com/schema/wrangler.json",
  "name": "talon-cloudflare",
  "main": "src/index.ts",
  "compatibility_date": "2026-06-13",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "vars": {
    "TALON_CONFIG_INLINE_YAML": "providers:\n  openai:\n    type: openai_compatible\n    name: openai\n    base_url: \"https://api.openai.com/v1\"\n    model: gpt-4o-mini\n    api_key:\n      source: env\n      key: OPENAI_API_KEY\ndefault_provider: openai\ncontrol_plane:\n  database:\n    driver: d1\n  message_broker:\n    driver: cf_queues\n  object_store:\n    driver: r2\n",
    "TALON_GATEWAY_CONTAINER_COUNT": "1",
    "TALON_WORKER_CONTAINER_COUNT": "1"
  },
  "d1_databases": [
    {
      "binding": "TALON_D1",
      "database_name": "talon-control-plane",
      "database_id": "00000000-0000-0000-0000-000000000000"
    }
  ],
  "r2_buckets": [
    {
      "binding": "TALON_R2",
      "bucket_name": "talon-objects"
    }
  ],
  "queues": {
    "producers": [
      {
        "binding": "SESSION_DISPATCH_QUEUE",
        "queue": "talon-session-dispatch"
      },
      {
        "binding": "RESOURCE_LIFECYCLE_QUEUE",
        "queue": "talon-resource-lifecycle"
      },
      {
        "binding": "SESSION_CONTROL_QUEUE",
        "queue": "talon-session-control"
      }
    ],
    "consumers": [
      {
        "queue": "talon-session-dispatch",
        "max_batch_size": 10
      },
      {
        "queue": "talon-resource-lifecycle",
        "max_batch_size": 10
      },
      {
        "queue": "talon-session-control",
        "max_batch_size": 10
      }
    ]
  },
  "durable_objects": {
    "bindings": [
      {
        "name": "GATEWAY_CONTAINER",
        "class_name": "GatewayContainer"
      },
      {
        "name": "WORKER_CONTAINER",
        "class_name": "WorkerContainer"
      },
      {
        "name": "SCHEDULE_SHARD",
        "class_name": "ScheduleShard"
      },
      {
        "name": "SESSION_STREAMS",
        "class_name": "SessionStreamShard"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": [
        "GatewayContainer",
        "WorkerContainer",
        "EnvoyContainer",
        "ScheduleShard",
        "SessionStreamShard"
      ]
    }
  ],
  "containers": [
    {
      "class_name": "GatewayContainer",
      "max_instances": 1,
      "image": "ghcr.io/impalasys/talon-runtime:latest"
    },
    {
      "class_name": "WorkerContainer",
      "max_instances": 1,
      "image": "ghcr.io/impalasys/talon-runtime:latest"
    }
  ]
}
