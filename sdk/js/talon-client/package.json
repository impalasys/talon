{
  "name": "@impalasys/talon-client",
  "version": "0.1.0",
  "description": "Generated Talon protobuf and RPC client bindings",
  "type": "module",
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/impalasys/talon.git",
    "directory": "sdk/js/talon-client"
  },
  "sideEffects": false,
  "files": [
    "dist",
    "src"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./gen/*": {
      "types": "./dist/gen/*.d.ts",
      "import": "./dist/gen/*.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsc -p tsconfig.json && node --test dist/index.test.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^1.10.1",
    "@connectrpc/connect": "^1.7.0"
  },
  "devDependencies": {
    "typescript": "^6.0.3"
  }
}
