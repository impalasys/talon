{
  "name": "@impalasys/talon-server",
  "version": "0.1.15",
  "description": "Local Talon node helper for tests and development",
  "type": "module",
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/impalasys/talon.git",
    "directory": "sdk/js/talon-server"
  },
  "files": [
    "dist",
    "src"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsc -p tsconfig.json && node --test dist/index.test.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "optionalDependencies": {
    "@impalasys/talon-node-darwin-arm64": "workspace:0.1.15",
    "@impalasys/talon-node-linux-x64": "workspace:0.1.15"
  },
  "devDependencies": {
    "@types/node": "^24.9.1",
    "typescript": "^6.0.3"
  }
}
